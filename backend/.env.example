# ── Instagram Graph API ───────────────────────────────────────────────────────
# Step-by-step cara dapat token:
# 1. Pergi https://developers.facebook.com → Create App → Consumer type
# 2. Add product: Instagram Graph API
# 3. Masuk ke Instagram Graph API → Generate Access Token (log in dengan akaun Instagram brand)
# 4. Exchange short-lived token (1h) → long-lived token (60 days) dengan arahan dalam README
# 5. Salin token tu ke bawah

# Long-lived user token (60 days, perlu renew sebelum expired)
INSTAGRAM_ACCESS_TOKEN=your_long_lived_token_here

# (Optional) Kalau nak store multiple brand tokens, boleh guna Supabase table nanti
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Port server
PORT=3001

# Frontend URL untuk CORS
FRONTEND_URL=http://localhost:5173
